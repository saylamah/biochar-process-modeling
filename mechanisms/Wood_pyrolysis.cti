"""
 Wood pyrolysis
 Tar gasification/oxidation
 Char gasification/oxidation
"""

units(length='cm', time='s', quantity='mol', act_energy='cal/mol')

ideal_gas(name='gas',
          elements="O H C N Ar",
          species="""H2      O2      H2O     CH4
                     CO      CO2     N2      AR
                     H2O(L)  WOOD    CHAR    TAR""",
          reactions='all',
          initial_state=state(temperature=300.0, pressure=OneAtm))

