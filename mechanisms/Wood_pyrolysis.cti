#-------------------------------------------------------------------------------
# Reaction data
#-------------------------------------------------------------------------------

# Tinaut (2008), Di Blasi (2004)
# Reaction 1 (Tinaut, 2008, Tab. 2-5)
reaction('H2O(L) => H2O', [5.13e+10, 0.0, 21018.439])

# Reaction 2 (p1) (Di Blasi, 2004) (Tab. 1)(Tab. 3,a)
reaction('WOOD => 0.35 CHAR + 0.045 CO + 0.1 CO2 + 0.002 H2 + 0.003 CH4 + 0.115 H2O + 0.385 TAR', [1.516e+3, 0.0, 25078.9])

# Reaction 3 (p2) (Di Blasi, 2004) (Tab. 1, 3)
reaction('TAR => 0.7 CO + 0.18 CO2 + 0.12 CH4', [4.26e+6, 0.0, 25641.753])

# Reaction 4 (c1) (Di Blasi, 2004)
#reaction('TAR + 0.8691 O2 => CO + 0.761 H2O', [9.2e+3, 1.0, 19107.7], order='TAR:1 O2:1')
reaction('TAR + 0.09 O2 => CO + 0.24 H2O', [9.2e+3, 1.0, 19107.7], order='TAR:1 O2:1')
# kmol/m3/s => 1e-3 mol/cm3/s, 9.2e+6 => 9.2e+3

# Reaction 5 (c2) (Di Blasi, 2004)
reaction('CH4 + 1.5 O2 => CO + 2 H2O', [9.2e+3, 1.0, 19107.7], order='CH4:1 O2:1')
# kmol/m3/s => 1e-3 mol/cm3/s, 9.2e+6 => 9.2e+3

# Reaction 6 (c3) (Di Blasi, 2004)
reaction('2 CO + O2 + H2O => 2 CO2 + H2O', [1.3e+8, 0.0, 30000.0], order='CO:1 O2:1 H2O:0.5')
# kmol/m3/s => 1e-3 mol/cm3/s, 1.3e+11 => 1.3e+8

# Reaction 7 (c4) (Di Blasi, 2004)
reaction('2 H2 + O2 => 2 H2O', [1.0e+8, 0.0, 19857.6], order='H2:1 O2:1')
# kmol/m3/s => 1e-3 mol/cm3/s, 1.0e+11 => 1.0e+8

# Reaction 8 (c5) (Di Blasi, 2004) (Heterogenous Reaction)
#reaction('CHAR + 0.8013 O2 => 0.5 CO + 2.5 CO2 + 0.1263 H2O', [7.3e+5, 0.0, 14695.0], order='O2:1')
reaction('CHAR + O2 => CO2', [7.3e+5, 0.0, 14695.0], order='O2:1')

# Reaction 9 (g1) (Di Blasi, 2004) (Heterogenous Reaction)
#reaction('CHAR + CO2 => 2 CO + 0.0237 H2O + 0.1026 H2', [1.074e+11, 0.0, 51614.0], order='CO2:1')
reaction('CHAR + CO2 => 2 CO', [1.074e+11, 0.0, 51614.0], order='CO2:1')

# Reaction 10 (g2) (Di Blasi, 2004) (Heterogenous Reaction)
#reaction('CHAR + 1.8974 H2 => CH4 + 0.0237 H2O', [1.2e+8, 0.0, 51820.0], order='H2:1')
reaction('CHAR + 2 H2 => CH4', [1.2e+8, 0.0, 51820.0], order='H2:1')

# Reaction 11 (g3) (Di Blasi, 2004) (Heterogenous Reaction)
#reaction('CHAR + 0.9763 H2O => CO + 1.1026 H2', [1.074e+11, 0.0, 51614.0], order='H2O:1')
reaction('CHAR + H2O => CO + H2', [1.074e+11, 0.0, 51614.0], order='H2O:1')

# Reaction 12 (wg1) (Tinaut, 2008, Tab. 4)
reaction('CO + H2O => CO2 + H2', [2.78e+6, 0.0, 3009.5])
# m3/mol/s => 1e6 cm3/mol/s, 2.78 => 2.78e+6

# Reaction 13 (wg2) (Tinaut, 2008, Tab. 4)
reaction('CO2 + H2 => CO + H2O', [1.05e8, 0.0, 10867.5])
# (2.78e+6/0.0265)*exp((-3009.5-7858)/(RT))
